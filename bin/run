#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
ROOT="$PWD"

ELIDE_REF="ghcr.io/elide-dev/elide:nightly"
SUITE="test262"
THREADS="${THREADS:-1}"
LOG=()
INCLUDE=()
RATCHET=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --elide) ELIDE_REF="$2"; shift 2;;
    --suite) SUITE="$2"; shift 2;;
    --threads) THREADS="$2"; shift 2;;
    --log) LOG=(--log); shift;;
    --include) INCLUDE=(--include "$2"); shift 2;;
    --ratchet) RATCHET=(--ratchet); shift;;
    *) echo "unknown arg: $1" >&2; exit 2;;
  esac
done

IMG="elide-harness:$(echo "$ELIDE_REF" | tr '/:@' '___')"
DIGEST="local"

if [[ -d "$ELIDE_REF" && -x "$ELIDE_REF/bin/elide" ]]; then
  # local install-directory mode (dir containing bin/elide + lib/)
  rm -rf .elide-install && cp -R "$ELIDE_REF" .elide-install
  DIGEST="$(shasum -a 256 .elide-install/bin/elide | cut -d' ' -f1)"
  docker build -f docker/harness.local.Dockerfile -t "$IMG" .
  rm -rf .elide-install
elif [[ -e "$ELIDE_REF" ]]; then
  echo "error: --elide local path must be an Elide install directory containing bin/elide and lib/, not a bare file: $ELIDE_REF" >&2
  exit 2
else
  # image mode: a bare tag (no '/' and no '@') is shorthand for the canonical image.
  if [[ "$ELIDE_REF" != *"/"* && "$ELIDE_REF" != *"@"* ]]; then
    FULL_REF="ghcr.io/elide-dev/elide:$ELIDE_REF"
  else
    FULL_REF="$ELIDE_REF"
  fi
  docker build -f docker/harness.Dockerfile --build-arg "ELIDE_REF=$FULL_REF" -t "$IMG" .
  DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$FULL_REF" 2>/dev/null | sed 's/.*@sha256://')"
  [[ -z "$DIGEST" ]] && DIGEST="$(echo "$FULL_REF" | sed 's/.*@sha256://')"
fi

SUITE_VERSION="$(git -C "$ROOT/suites/$SUITE" rev-parse HEAD 2>/dev/null || echo unknown)"

# --ratchet writes expectations/<suite>.ratchet.toml back to the host, so the
# expectations mount must be writable for ratchet runs (read-only otherwise).
EXP_MODE=ro
[[ ${#RATCHET[@]} -gt 0 ]] && EXP_MODE=rw

mkdir -p "$ROOT/reports"
docker run --rm \
  -v "$ROOT/suites:/work/suites:ro" \
  -v "$ROOT/expectations:/work/expectations:$EXP_MODE" \
  -v "$ROOT/reports:/work/reports" \
  -v "$ROOT/registry.toml:/work/registry.toml:ro" \
  "$IMG" \
  run "$SUITE" \
  --elide-path /opt/elide/bin/elide \
  --digest "$DIGEST" \
  --suite-root /work/suites \
  --reports /work/reports \
  --expectations /work/expectations \
  --threads "$THREADS" \
  --suite-version "$SUITE_VERSION" \
  ${LOG[@]+"${LOG[@]}"} \
  ${INCLUDE[@]+"${INCLUDE[@]}"} \
  ${RATCHET[@]+"${RATCHET[@]}"}
