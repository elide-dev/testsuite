# Keep the build context lean and reproducible. In particular, exclude
# node_modules so `COPY harness/ ./` cannot shadow the image's frozen,
# patched `bun install` with whatever is on the host.
**/node_modules
**/.bun
suites
reports
.harness
.git
.github
.devcontainer
docs
.superpowers
*.log
.DS_Store
# NOTE: .elide-bin is intentionally NOT ignored — harness.local.Dockerfile
# copies .elide-bin/elide from the build context.
